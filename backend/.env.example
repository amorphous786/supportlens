# ══════════════════════════════════════════════════════════════════════════════
# SupportLens — environment configuration
#
# Quick-start:
#   cp .env.example .env
#   docker compose up --build -d
#
# No external API key is required.
# SupportLens uses Ollama (a free, local LLM runtime) — no OpenAI / Anthropic key needed.
# Ollama must have the model pulled before traces will classify:
#   docker exec supportlens_ollama ollama pull llama3
#
# ── Simulate dependency failures (for testing) ────────────────────────────────
#
#   DB failure (health → "unhealthy"):
#     docker compose stop db
#     curl localhost:8000/health           # status: unhealthy, database: unavailable
#     docker compose start db
#     docker compose restart backend       # pool_pre_ping reconnects automatically
#
#   LLM failure (health → "degraded"):
#     docker compose stop ollama
#     curl localhost:8000/health           # status: degraded, ollama: unavailable
#     docker compose start ollama
#
#   Model not pulled (health → "degraded"):
#     Set OLLAMA_MODEL=nonexistent-model below, then:
#     docker compose up -d --build
#     curl localhost:8000/health           # status: degraded, model_available: false
#
# ══════════════════════════════════════════════════════════════════════════════

DEBUG=false
LOG_LEVEL=INFO

# PostgreSQL — used by the 'db' service in docker-compose.yml.
# Change only if you bring your own PostgreSQL instance.
DATABASE_URL=postgresql://supportlens:supportlens@db:5432/supportlens

# Ollama — must match the service name in docker-compose.yml.
# To use a different model: change OLLAMA_MODEL and pull it inside the container.
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3

# Comma-separated allowed CORS origins (plain string, NOT JSON array)
CORS_ORIGINS=http://localhost:3000

MAX_MESSAGE_LENGTH=2000
